# ─────────────────────────────────────────────────────────────────────────────
#  VPNOODLES BOT — Environment Variables
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=vpnoodles_bot
ADMIN_IDS=123456789,987654321          # comma-separated Telegram user IDs

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production                    # development | production
LOG_LEVEL=info                         # error | warn | info | debug
PORT=3000                              # webhook port (if using webhook mode)
WEBHOOK_DOMAIN=https://yourdomain.com  # required for webhook mode only
BOT_MODE=polling                       # polling | webhook

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost                      # use 'postgres' inside Docker Compose
DB_PORT=5432
DB_NAME=vpnoodles
DB_USER=vpnoodles_user
DB_PASSWORD=strong_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false                           # true only for managed cloud Postgres

# ── VPN Panel — Remnawave ─────────────────────────────────────────────────────
VPN_PANEL_URL=https://your-panel.com   # Remnawave panel URL (no trailing slash)
VPN_PANEL_USERNAME=admin               # legacy (login UI)
VPN_PANEL_PASSWORD=admin_password      # legacy
VPN_API_TOKEN=                         # Remnawave API token from admin dashboard
VPN_SUBSCRIPTION_TOKEN=                # subscription API token (if required)
VPN_PANEL_TLS_INSECURE=false           # true only for self-signed HTTPS to the panel

# Subscription link domain (often same as panel or CDN)
VPN_SERVER_DOMAIN=https://your-panel.com
VPN_SUB_PATH=/api/sub
# Optional tag prefix for users on the panel (combined with plan slug, e.g. shop-basic)
VPN_USER_TAG_PREFIX=
# Comma-separated internal squad UUIDs for new users
VPN_INTERNAL_SQUAD_UUIDS=

# ── Payments ──────────────────────────────────────────────────────────────────
STARS_ENABLED=true                     # Telegram Stars payments

# CryptoBot (Crypto Pay) — https://t.me/CryptoBot → /pay → Create App
CRYPTO_PAY_ENABLED=true
CRYPTO_PAY_TOKEN=your_cryptopay_token_here
CRYPTO_PAY_URL=https://pay.crypt.bot   # mainnet; testnet: https://testnet-pay.crypt.bot

# YooKassa (optional)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── Subscription Plans ────────────────────────────────────────────────────────
PLAN_TRIAL_DAYS=3
PLAN_TRIAL_TRAFFIC_GB=1

# ── Referral ──────────────────────────────────────────────────────────────────
REFERRAL_BONUS_DAYS=7                  # days added per referral

# ── Notifications ─────────────────────────────────────────────────────────────
NOTIFY_EXPIRY_DAYS_BEFORE=3            # warn user N days before expiry

# ── Proxy (optional) ──────────────────────────────────────────────────────────
# Only needed if Telegram API is blocked on your network (e.g. local dev in Russia)
HTTPS_PROXY=                           # http://user:pass@host:port
SOCKS5_PROXY=                          # socks5://user:pass@host:port

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_random_string
ENCRYPTION_KEY=32_char_random_key_here
