# ─────────────────────────────────────────────
#  VPNOODLES BOT — Environment Variables
# ─────────────────────────────────────────────

# ── Telegram ──────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=vpnoodles_bot
ADMIN_IDS=123456789,987654321          # comma-separated Telegram user IDs

# ── App ───────────────────────────────────────
NODE_ENV=development                   # development | production
LOG_LEVEL=info                         # error | warn | info | debug
PORT=3000                              # webhook port (if using webhook mode)
WEBHOOK_DOMAIN=https://yourdomain.com  # required for webhook mode
BOT_MODE=polling                       # polling | webhook

# ── PostgreSQL ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vpnoodles
DB_USER=vpnoodles_user
DB_PASSWORD=strong_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false                           # true only for managed cloud Postgres (RDS, Supabase, etc.)
                                       # keep false for local/Docker postgres

# ── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
SESSION_TTL=86400                      # session TTL in seconds (24h)

# ── VPN / Proxy Panel ─────────────────────────
# 3x-ui / Marzban / XUI panel API
VPN_PANEL_URL=https://your-panel.com
VPN_PANEL_USERNAME=admin
VPN_PANEL_PASSWORD=admin_password
VPN_PANEL_TYPE=marzban                 # marzban | 3xui | outline

# ── Payments ──────────────────────────────────
# Telegram Stars (built-in)
STARS_ENABLED=true

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Cryptomus (crypto payments)
CRYPTOMUS_API_KEY=
CRYPTOMUS_MERCHANT_ID=

# ── Subscription Plans (defaults, override in DB) ──
PLAN_TRIAL_DAYS=3
PLAN_TRIAL_TRAFFIC_GB=1

# ── Referral ──────────────────────────────────
REFERRAL_BONUS_DAYS=7                  # days added for each referral

# ── Notifications ─────────────────────────────
NOTIFY_EXPIRY_DAYS_BEFORE=3            # warn user N days before expiry

# ── Security ──────────────────────────────────
JWT_SECRET=change_me_to_random_string
ENCRYPTION_KEY=32_char_random_key_here
