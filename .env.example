# ─────────────────────────────────────────────────────────────────────────────
#  VPNOODLES BOT — Environment Variables
#  Скопируйте в .env и заполните значения.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Получить токен: @BotFather → /newbot
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=vpnoodles_bot
# Ваш Telegram ID (для доступа к /admin). Узнать: @userinfobot
ADMIN_IDS=123456789

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
BOT_MODE=polling
# BOT_MODE=webhook — для продакшена с доменом
# PORT=3000
# WEBHOOK_DOMAIN=https://yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost          # внутри Docker Compose: postgres
DB_PORT=5432
DB_NAME=vpnoodles
DB_USER=vpnoodles_user
DB_PASSWORD=strong_password_here
DB_SSL=false               # true только для managed cloud Postgres (RDS, Supabase)

# ── Remnawave VPN Panel ───────────────────────────────────────────────────────
# URL панели без слеша в конце
VPN_PANEL_URL=https://your-remnawave-panel.com

# Способ авторизации (выберите один):
#
# Вариант 1 — API Token (рекомендуется, надёжнее)
# Получить: Remnawave → Settings → API Tokens → Create
VPN_API_TOKEN=

# Вариант 2 — логин/пароль (если нет API Token)
VPN_PANEL_USERNAME=admin
VPN_PANEL_PASSWORD=your_panel_password

# Домен для ссылок подписки (обычно совпадает с VPN_PANEL_URL)
# Если у вас отдельный CDN/домен для подписок — укажите его
VPN_SERVER_DOMAIN=https://your-remnawave-panel.com
# Путь подписки — по умолчанию в Remnawave: /api/sub
VPN_SUB_PATH=/api/sub

# Тег для пробных пользователей в Remnawave (для фильтрации в панели)
TRIAL_REMNAWAVE_TAG=trial_user

# Префикс тега для платных пользователей (необязательно)
# Пример: vpnoodles → тег будет "vpnoodles-basic_1m"
VPN_USER_TAG_PREFIX=

# Добавление новых пользователей в определённый отряд (squad) в Remnawave
# Получить UUID отряда: Remnawave → Squads → выбрать отряд → UUID в URL
VPN_DEFAULT_SQUAD=

# true — только если панель использует самоподписанный SSL сертификат
VPN_TLS_INSECURE=false

# ── Пробный период ────────────────────────────────────────────────────────────
PLAN_TRIAL_DAYS=7
PLAN_TRIAL_TRAFFIC_GB=10

# ── Оплата ────────────────────────────────────────────────────────────────────
# Telegram Stars (встроенная оплата в Telegram)
STARS_ENABLED=true

# CryptoBot — получить токен: @CryptoBot → /pay → Create App
# Тестнет: @CryptoTestnetBot, URL: https://testnet-pay.crypt.bot
CRYPTO_PAY_ENABLED=false
CRYPTO_PAY_TOKEN=
CRYPTO_PAY_URL=https://pay.crypt.bot

# YooKassa — https://yookassa.ru
# Получить: Личный кабинет → Настройки → API-ключи
YOOKASSA_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── Реферальная программа ─────────────────────────────────────────────────────
# Количество бонусных дней за каждого приглашённого
REFERRAL_BONUS_DAYS=7

# ── Уведомления ───────────────────────────────────────────────────────────────
# За сколько дней до истечения подписки предупреждать пользователя
NOTIFY_EXPIRY_DAYS_BEFORE=3

# ── Прокси (необязательно) ────────────────────────────────────────────────────
# Нужен только если Telegram API заблокирован в вашей сети
HTTPS_PROXY=
SOCKS5_PROXY=
